{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "keon.run_manifest.v1.schema.json",
  "title": "Keon Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "timestamp",
    "env",
    "layer",
    "suite",
    "scenarioId",
    "status",
    "source",
    "evidence"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1.0.0"
    },
    "runId": {
      "type": "string",
      "minLength": 8
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "env": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "minLength": 1
    },
    "suite": {
      "type": "string",
      "enum": [
        "smoke",
        "unit",
        "contract",
        "integration",
        "e2e",
        "chaos",
        "perf",
        "obs"
      ]
    },
    "scenarioId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "skip",
        "abort"
      ]
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git",
        "build"
      ],
      "properties": {
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sha"
          ],
          "properties": {
            "sha": {
              "type": "string",
              "minLength": 7
            },
            "repo": {
              "type": "string"
            },
            "branch": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            }
          }
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "system"
          ],
          "properties": {
            "system": {
              "type": "string",
              "minLength": 1
            },
            "buildId": {
              "type": "string"
            },
            "runNumber": {
              "type": "string"
            },
            "pipeline": {
              "type": "string"
            },
            "job": {
              "type": "string"
            }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenantId": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "correlationId": {
          "type": "string"
        },
        "traceId": {
          "type": "string"
        },
        "workflowId": {
          "type": "string"
        },
        "policyId": {
          "type": "string"
        },
        "policyVersion": {
          "type": "string"
        },
        "ruleSetHash": {
          "type": "string"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latencyMs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "p50": {
              "type": "number",
              "minimum": 0
            },
            "p95": {
              "type": "number",
              "minimum": 0
            },
            "p99": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requests": {
              "type": "integer",
              "minimum": 0
            },
            "retries": {
              "type": "integer",
              "minimum": 0
            },
            "errors": {
              "type": "integer",
              "minimum": 0
            },
            "duplicatesPrevented": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "rootCauseHint": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage",
        "artifacts"
      ],
      "properties": {
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "account",
            "container",
            "prefix"
          ],
          "properties": {
            "account": {
              "type": "string",
              "const": "keonreceipts"
            },
            "container": {
              "type": "string",
              "minLength": 1
            },
            "prefix": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "blobUrl",
              "sha256"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "blobUrl": {
                "type": "string"
              },
              "sha256": {
                "type": "string",
                "minLength": 32
              },
              "contentType": {
                "type": "string"
              },
              "bytes": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
