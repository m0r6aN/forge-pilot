{
  "openapi": "3.1.0",
  "info": {
    "title": "ForgePilot Campaign API",
    "version": "0.1.0",
    "description": "Thin API layer for OMEGA-native brand campaign generation"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/v1/campaigns": {
      "post": {
        "summary": "Create a new brand campaign",
        "operationId": "createCampaign",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCampaignRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Campaign created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Federation Core unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/campaigns/{campaign_id}": {
      "get": {
        "summary": "Get campaign status",
        "operationId": "getCampaignStatus",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/campaigns/{campaign_id}/artifacts": {
      "get": {
        "summary": "Get campaign artifacts",
        "operationId": "getCampaignArtifacts",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifacts retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Campaign not completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Service is alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["ok"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Readiness probe",
        "operationId": "readinessCheck",
        "responses": {
          "200": {
            "description": "Service is ready",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["ready"]
                    },
                    "federation_available": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Service not ready",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["unavailable"]
                    },
                    "federation_available": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCampaignRequest": {
        "type": "object",
        "required": ["business_idea", "target_audience", "tenant_id", "actor_id"],
        "properties": {
          "business_idea": {
            "type": "string",
            "description": "Core business concept or product description",
            "minLength": 10,
            "maxLength": 2000
          },
          "target_audience": {
            "type": "string",
            "description": "Target demographic or market segment",
            "minLength": 5,
            "maxLength": 500
          },
          "brand_values": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional brand values or principles",
            "maxItems": 10
          },
          "tenant_id": {
            "type": "string",
            "format": "uuid",
            "description": "Tenant identifier for multi-tenancy"
          },
          "actor_id": {
            "type": "string",
            "description": "User or system actor initiating the campaign"
          },
          "correlation_id": {
            "type": "string",
            "format": "uuid",
            "description": "Optional correlation ID for tracing"
          }
        }
      },
      "CampaignResponse": {
        "type": "object",
        "required": ["campaign_id", "status", "created_at", "correlation_id"],
        "properties": {
          "campaign_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "in_progress"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "correlation_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CampaignStatusResponse": {
        "type": "object",
        "required": ["campaign_id", "status", "created_at", "updated_at"],
        "properties": {
          "campaign_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "in_progress", "completed", "failed"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "progress": {
            "type": "object",
            "properties": {
              "current_phase": {
                "type": "string"
              },
              "completion_percentage": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "last_message": {
                "type": "string"
              }
            }
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "ArtifactsResponse": {
        "type": "object",
        "required": ["campaign_id", "artifacts"],
        "properties": {
          "campaign_id": {
            "type": "string",
            "format": "uuid"
          },
          "artifacts": {
            "type": "object",
            "properties": {
              "brand_name": {
                "type": "string"
              },
              "tagline": {
                "type": "string"
              },
              "domain_suggestions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "domain": {
                      "type": "string"
                    },
                    "available": {
                      "type": "boolean"
                    },
                    "price": {
                      "type": "number"
                    }
                  }
                }
              },
              "brand_guidelines": {
                "type": "object",
                "properties": {
                  "colors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "typography": {
                    "type": "string"
                  },
                  "voice": {
                    "type": "string"
                  }
                }
              },
              "legal_review": {
                "type": "object",
                "properties": {
                  "trademark_status": {
                    "type": "string"
                  },
                  "risks": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message"
              },
              "correlation_id": {
                "type": "string",
                "format": "uuid",
                "description": "Request correlation ID for tracing"
              },
              "details": {
                "type": "object",
                "description": "Additional error context"
              }
            }
          }
        }
      }
    }
  }
}
