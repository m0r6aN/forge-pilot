{
  "name": "forgepilot-ai",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint:voice": "tsx tools/behavioral-linter/scan.ts --fail-on=critical",
    "lint:voice:strict": "tsx tools/behavioral-linter/scan.ts --fail-on=warning",
    "lint:voice:test": "tsx --test tools/behavioral-linter/*.test.ts src/lib/omega/*.test.ts",
    "test:auth": "tsx --test src/lib/auth/passwordless-flow.test.ts",
    "lint": "eslint src --ext .ts,.tsx || node -e \"process.exit(0)\" && npm run lint:voice",
    "precommit": "npm run lint:voice",
    "test-brand": "node test-brand-generator.js",
    "omega:register": "node scripts/omega-register.mjs",
    "omega:blueprint-worker": "tsx scripts/blueprint-worker.ts",
    "test:e2e": "playwright test --project=forgepilot-e2e",
    "test:site": "playwright test --project=site-smoke",
    "test:component": "playwright test --project=component",
    "test:all": "playwright test",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@azure/identity": "^4.13.0",
    "@omega/sdk": "file:../omega-sdk-ts/omega-sdk-1.0.0.tgz",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bcrypt-ts": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "canonicalize": "^2.1.0",
    "chroma-js": "^2.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color-hash": "^1.0.0",
    "dotenv": "^17.3.1",
    "firebase-admin": "^12.0.0",
    "json-stable-stringify": "^1.3.0",
    "jszip": "^3.10.1",
    "lightningcss": "^1.31.1",
    "lightningcss-win32-x64-msvc": "^1.31.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.4",
    "next-themes": "^0.4.6",
    "openai": "^4.0.0",
    "pg": "^8.18.0",
    "react": "^19.2.3",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.3",
    "react-icons": "^4.10.1",
    "redis": "^4.7.1",
    "resend": "^6.9.2",
    "rgb-hex": "^2.0.0",
    "server-only": "^0.0.1",
    "stripe": "^20.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.1",
    "tweetnacl": "^1.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.4",
    "postcss": "^8.5.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
