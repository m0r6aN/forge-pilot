{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.keon.systems/omega/workflows/forgepilot.blueprint.v1/output.schema.json",
  "title": "ForgePilot Blueprint v1 Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["blueprint"],
  "properties": {
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "executiveThesis",
        "offerArchitecture",
        "monetizationModel",
        "distributionStrategy",
        "ninetyDayPlan",
        "riskMitigation",
        "firstFiveActions"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 8, "maxLength": 200 },
        "executiveThesis": { "type": "string", "minLength": 60, "maxLength": 1800 },
        "offerArchitecture": { "type": "string", "minLength": 120, "maxLength": 3200 },
        "monetizationModel": { "type": "string", "minLength": 120, "maxLength": 2200 },
        "distributionStrategy": { "type": "string", "minLength": 120, "maxLength": 2200 },
        "ninetyDayPlan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weeks1to3", "weeks4to8", "weeks9to12"],
          "properties": {
            "weeks1to3": { "type": "string", "minLength": 120, "maxLength": 2200 },
            "weeks4to8": { "type": "string", "minLength": 120, "maxLength": 2200 },
            "weeks9to12": { "type": "string", "minLength": 120, "maxLength": 2200 }
          }
        },
        "riskMitigation": { "type": "string", "minLength": 80, "maxLength": 1800 },
        "firstFiveActions": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 12, "maxLength": 260 }
        }
      }
    }
  }
}
